{
    "headers": [
        {
            "source": "/.well-known/assetlinks.json",
            "headers": [
                { "key": "Content-Type",                "value": "application/json" },
                { "key": "Access-Control-Allow-Origin", "value": "*" },
                { "key": "Cache-Control",               "value": "public, max-age=3600" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/.well-known/(.*)",
            "destination": "/.well-known/$1"
        },
        {
            "source": "/download/wms-coletor",
            "destination": "/platform/download/wms-coletor.html"
        },
        {
            "source": "/download/apk",
            "destination": "/platform/Instala%C3%A7%C3%A3o%20WMS%20COLETOR/ParreiraLog%20WMS.apk"
        },
        {
            "source": "/",
            "destination": "/platform/index.html"
        },
        {
            "source": "/modules/(.*)",
            "destination": "/platform/modules/$1"
        },
        {
            "source": "/core/(.*)",
            "destination": "/platform/core/$1"
        },
        {
            "source": "/platform/(.*)",
            "destination": "/platform/$1"
        },
        {
            "source": "/web/(.*)",
            "destination": "/web/$1"
        }
    ]
}